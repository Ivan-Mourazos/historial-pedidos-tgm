# Conexión a SQL Server (schema "historico" dentro de la base de datos).
# Copia este archivo a .env.local y rellena los valores reales.
# Estas variables SOLO se usan en el servidor; no llevan prefijo NEXT_PUBLIC_.

# Host o IP del servidor. Admite formato "SERVIDOR\INSTANCIA" (ej. SERVIDOR\SQLEXPRESS).
SQLSERVER_HOST=

# Puerto (por defecto 1433 si se omite).
SQLSERVER_PORT=1433

# Base de datos.
SQLSERVER_DATABASE=HIST_PEDIDOS

# Login y contraseña SQL.
SQLSERVER_USER=
SQLSERVER_PASSWORD=

# Cifrado TLS. En red interna suele ir en false; en Azure SQL debe ser true.
SQLSERVER_ENCRYPT=false

# Confiar en certificado autofirmado (típico en servidores locales). true por defecto.
SQLSERVER_TRUST_SERVER_CERT=true

# Localización de pedidos DWG/Excel desde la web.
# Una o varias carpetas raíz donde buscar NUMERO_PEDIDO.dwg, separadas por punto y coma.
# La app prueba primero la carpeta del año: AR26xxxxx -> 2026\AR26xxxxx.dwg.
#
# En desarrollo Windows:
# ZWCAD_DWG_ROOTS=\\STINKOR\Oftecnica
#
# En servidor Linux con la carpeta montada:
ZWCAD_DWG_ROOTS=/mnt/oftecnica

# Ruta equivalente vista desde los PCs Windows. Debe ir en el mismo orden que ZWCAD_DWG_ROOTS.
# Sirve para abrir Excel/CAD en el equipo del usuario cuando el servidor es Linux.
ZWCAD_CLIENT_ROOTS=\\stinkor\oftecnica

# Opcional. Si se deja vacío, Windows abrirá el .dwg con la aplicación asociada.
# Ejemplo: C:\Program Files\ZWSOFT\ZWCAD 2025\ZWCAD.exe
ZWCAD_EXE=
